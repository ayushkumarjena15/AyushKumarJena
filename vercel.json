{
    "redirects": [
        { "source": "/blog", "destination": "/blogs", "permanent": true },
        { "source": "/project", "destination": "/projects", "permanent": true },
        { "source": "/contact", "destination": "/book", "permanent": true }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
